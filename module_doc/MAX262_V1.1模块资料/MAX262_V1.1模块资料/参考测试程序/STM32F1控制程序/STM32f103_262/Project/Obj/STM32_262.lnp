--cpu Cortex-M3
".\obj\main.o"
".\obj\delay.o"
".\obj\peripheralinit.o"
".\obj\max262.o"
".\obj\misc.o"
".\obj\stm32f10x_gpio.o"
".\obj\stm32f10x_rcc.o"
".\obj\core_cm3.o"
".\obj\system_stm32f10x.o"
".\obj\startup_stm32f10x_hd.o"
--strict --scatter ".\Obj\STM32_262.sct"
