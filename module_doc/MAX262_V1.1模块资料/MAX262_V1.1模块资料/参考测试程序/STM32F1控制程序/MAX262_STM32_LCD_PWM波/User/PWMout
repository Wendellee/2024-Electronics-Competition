//-----------------------------------------------------------------
// void PeripheralInit(void)
//-----------------------------------------------------------------
// 函数功能: 外设初始化函数
// 入口参数: 无 
// 返 回 值: 无
// 全局变量: 无
// 注意事项: 无
//-----------------------------------------------------------------
void NVIC_TIM2_Config(void)
{
	NVIC_InitTypeDef NVIC_InitStructure;          // 定义结构体
	
	NVIC_PriorityGroupConfig(NVIC_PriorityGroup_0);          // 设为第0组
	NVIC_InitStructure.NVIC_IRQChannel = TIM2_IRQn;          // 定时器2打开 
	NVIC_InitStructure.NVIC_IRQChannelPreemptionPriority = 0;  // 先占优先级为0
	NVIC_InitStructure.NVIC_IRQChannelSubPriority = 0;       // 副优先级为0
	NVIC_InitStructure.NVIC_IRQChannelCmd = ENABLE;          // 使能打开
	 
	NVIC_Init(&NVIC_InitStructure);                     //
}

//-----------------------------------------------------------------
// void PeripheralInit(void)
//-----------------------------------------------------------------
// 函数功能: 外设初始化函数
// 入口参数: 无 
// 返 回 值: 无
// 全局变量: 无
// 注意事项: 无
//-----------------------------------------------------------------
void TIM2_Config(void)
{
	TIM_TimeBaseInitTypeDef TIM_TimeBaseInitStructure;          // 定义结构体
	
	RCC_APB1PeriphClockCmd(RCC_APB1Periph_TIM2, ENABLE);        // 打开时钟使能
	TIM_TimeBaseInitStructure.TIM_Prescaler = 1-1;              // 预分频数设置
	TIM_TimeBaseInitStructure.TIM_CounterMode = TIM_CounterMode_Up;              // 向上计数
	TIM_TimeBaseInitStructure.TIM_Period = 15-1;                // 装载值
	TIM_TimeBaseInitStructure.TIM_ClockDivision = 0;            // 设置时钟: 不分割
	 
	TIM_TimeBaseInit(TIM2, &TIM_TimeBaseInitStructure);
}

